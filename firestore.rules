rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBoardMember(boardId) {
      return signedIn()
        && exists(/databases/$(database)/documents/finance_boards/$(boardId))
        && (
          get(/databases/$(database)/documents/finance_boards/$(boardId)).data.ownerId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/finance_boards/$(boardId)).data.memberIds
        );
    }

    function canReadFinanceResource(data) {
      return signedIn()
        && (
          data.userId == request.auth.uid
          || (data.boardId is string && isBoardMember(data.boardId))
        );
    }

    match /finance_boards/{boardId} {
      allow read: if isBoardMember(boardId);
      allow create, update, delete: if false;
    }

    match /finance_items/{itemId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_categories/{categoryId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_cards/{cardId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_fixed_templates/{templateId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_board_invites/{inviteId} {
      allow read, write: if false;
    }

    match /finance_debts/{debtId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_debt_payments/{paymentId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_budgets/{budgetId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_goals/{goalId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /finance_templates/{templateId} {
      allow read: if canReadFinanceResource(resource.data);
      allow create, update, delete: if false;
    }

    match /rooms/{roomId} {
      allow get: if true;
      allow list: if false;
      allow create: if request.resource.data.keys().hasOnly([
          "roomName",
          "requireName",
          "createdAt",
          "expiresAt"
        ])
        && request.resource.data.roomName is string
        && request.resource.data.roomName.size() > 0
        && request.resource.data.roomName.size() <= 120
        && request.resource.data.requireName is bool
        && request.resource.data.expiresAt is timestamp;
      allow update, delete: if false;

      match /cards/{cardId} {
        allow read: if exists(/databases/$(database)/documents/rooms/$(roomId));
        allow create: if exists(/databases/$(database)/documents/rooms/$(roomId))
          && request.resource.data.keys().hasOnly([
            "category",
            "text",
            "likes",
            "dislikes",
            "author",
            "createdAt"
          ])
          && request.resource.data.category in ["bom", "ruim", "melhorar"]
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.author is string
          && request.resource.data.author.size() > 0
          && request.resource.data.author.size() <= 80
          && request.resource.data.likes == 0
          && request.resource.data.dislikes == 0;
        allow update: if exists(/databases/$(database)/documents/rooms/$(roomId))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likes", "dislikes"])
          && request.resource.data.likes is int
          && request.resource.data.dislikes is int
          && request.resource.data.likes >= resource.data.likes
          && request.resource.data.dislikes >= resource.data.dislikes
          && request.resource.data.likes <= resource.data.likes + 1
          && request.resource.data.dislikes <= resource.data.dislikes + 1;
        allow delete: if false;
      }
    }
  }
}
